rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 로그인 사용자만 업로드 가능
    match /products/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 그 외 경로는 읽기만 허용(필요 시 정책 강화 가능)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}

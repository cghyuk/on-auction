rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function uploadsEnabled() {
      // 긴급 차단 스위치: 업로드를 멈추려면 true -> false 로 변경
      return true;
    }

    // 로그인 사용자만 업로드 가능
    match /products/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if uploadsEnabled() && request.auth != null && request.auth.uid == uid;
    }

    // 그 외 경로는 읽기만 허용(필요 시 정책 강화 가능)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
